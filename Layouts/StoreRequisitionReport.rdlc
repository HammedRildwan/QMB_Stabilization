<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString />
      </ConnectionProperties>
      <rd:DataSourceID>DataSource</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <ReportSections>
    <ReportSection>
      <Body>
        <Height>2in</Height>
        <ReportItems>
          <Textbox Name="ReportTitle">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=First(Fields!ReportTitle.Value)</Value>
                    <Style>
                      <FontSize>16pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.1in</Top>
            <Left>0.1in</Left>
            <Height>0.3in</Height>
            <Width>6in</Width>
            <Style>
              <Border>
                <Style>None</Style>
              </Border>
            </Style>
          </Textbox>
        </ReportItems>
      </Body>
      <Width>8.5in</Width>
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <LeftMargin>0.5in</LeftMargin>
        <RightMargin>0.5in</RightMargin>
        <TopMargin>0.5in</TopMargin>
        <BottomMargin>0.5in</BottomMargin>
      </Page>
    </ReportSection>
  </ReportSections>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <rd:ReportID>store-requisition-report</rd:ReportID>
  <DataSets>
    <DataSet Name="DataSet_Result">
      <Fields>
        <Field Name="No_">
          <DataField>No_</DataField>
        </Field>
        <Field Name="RequestDate">
          <DataField>RequestDate</DataField>
        </Field>
        <Field Name="Requester">
          <DataField>Requester</DataField>
        </Field>
        <Field Name="Status">
          <DataField>Status</DataField>
        </Field>
        <Field Name="StoreLocation">
          <DataField>StoreLocation</DataField>
        </Field>
        <Field Name="RequestType">
          <DataField>RequestType</DataField>
        </Field>
        <Field Name="Justification">
          <DataField>Justification</DataField>
        </Field>
        <Field Name="AssetNo">
          <DataField>AssetNo</DataField>
        </Field>
        <Field Name="MaintenanceType">
          <DataField>MaintenanceType</DataField>
        </Field>
        <Field Name="Posted">
          <DataField>Posted</DataField>
        </Field>
        <Field Name="PostedDateTime">
          <DataField>PostedDateTime</DataField>
        </Field>
        <Field Name="PostedBy">
          <DataField>PostedBy</DataField>
        </Field>
        <Field Name="ShortcutDimension1Code">
          <DataField>ShortcutDimension1Code</DataField>
        </Field>
        <Field Name="ShortcutDimension2Code">
          <DataField>ShortcutDimension2Code</DataField>
        </Field>
        <Field Name="CompanyName">
          <DataField>CompanyName</DataField>
        </Field>
        <Field Name="ReportTitle">
          <DataField>ReportTitle</DataField>
        </Field>
        <Field Name="PrintDate">
          <DataField>PrintDate</DataField>
        </Field>
        <Field Name="LineNo">
          <DataField>LineNo</DataField>
        </Field>
        <Field Name="ItemNo">
          <DataField>ItemNo</DataField>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
        </Field>
        <Field Name="UnitOfMeasure">
          <DataField>UnitOfMeasure</DataField>
        </Field>
        <Field Name="QuantityRequested">
          <DataField>QuantityRequested</DataField>
        </Field>
        <Field Name="QuantityRequestedFormat">
          <DataField>QuantityRequestedFormat</DataField>
        </Field>
        <Field Name="QuantityToIssue">
          <DataField>QuantityToIssue</DataField>
        </Field>
        <Field Name="QuantityToIssueFormat">
          <DataField>QuantityToIssueFormat</DataField>
        </Field>
        <Field Name="AvailableQuantity">
          <DataField>AvailableQuantity</DataField>
        </Field>
        <Field Name="AvailableQuantityFormat">
          <DataField>AvailableQuantityFormat</DataField>
        </Field>
        <Field Name="UnitPrice">
          <DataField>UnitPrice</DataField>
        </Field>
        <Field Name="UnitPriceFormat">
          <DataField>UnitPriceFormat</DataField>
        </Field>
        <Field Name="Amount">
          <DataField>Amount</DataField>
        </Field>
        <Field Name="AmountFormat">
          <DataField>AmountFormat</DataField>
        </Field>
        <Field Name="LocationCode">
          <DataField>LocationCode</DataField>
        </Field>
        <Field Name="FixedAssetNo">
          <DataField>FixedAssetNo</DataField>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource</DataSourceName>
        <CommandText />
      </Query>
    </DataSet>
  </DataSets>
</Report>